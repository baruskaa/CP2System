    <Component class="javax.swing.JLabel" name="Aboutus_text3">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="The House of 7 is an buffet concept that hosts seven unique culinary stations,   "/>
        <Property name="name" type="java.lang.String" value="Aboutus_text2" noResource="true"/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text4">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="Each station has a unique flavors and personality."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text5">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Kysha&#x2019;s Kitchen serves comforting homemade favorites "/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text6">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="that feel warm, familiar, and satisfying meal prepared with love at home."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text7">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Sveska&#x2019;s European Table presents a selection of European-inspired cuisine,"/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text8">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="highlighting traditional dishes, breads, and refined flavors from across the continent."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text11">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Caloy&#x2019;s Grill Station focuses on expertly grilled and savory meats prepared fresh to order."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text12">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Wesley&#x2019;s Western Comfort offers hearty Western favorites and classic comfort dishes."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text13">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Yanna&#x2019;s Sweet Corner provides a wide assortment of desserts, pastries, and sweets,"/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text15">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Anne&#x2019;s Healthy Garden features fresh salads, vegetables, and lighter options, this for guests"/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text16">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="looking for more balanced meals."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text9">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="-Stacy&#x2019;s Asian Fusion showcases a blend of Asian culinary influences, while combining traditional,   "/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text14">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="perfect for guests that has a sweet tooth."/>
      </Properties>
    </Component>
    <Component class="javax.swing.JLabel" name="Aboutus_text10">
      <Properties>
        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
          <Font name="Segoe UI Semibold" size="12" style="0"/>
        </Property>
        <Property name="text" type="java.lang.String" value="nostalgic flavors, with a modern touch. "/>
